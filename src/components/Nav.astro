---
const links = [
  { href: '/work',    label: 'Work' },
  { href: '/writing', label: 'Writing' },
  { href: '/about',   label: 'About' },
];
const { pathname } = Astro.url;
---
<nav>
  <ul class="flex gap-6 list-none text-sm">
    {links.map(({ href, label }) => (
      <li>
        <a
          href={href}
          class:list={[
            'no-underline',
            pathname.startsWith(href) ? 'font-semibold text-brand-primary' : 'text-brand-muted hover:text-brand-primary'
          ]}
        >
          {label}
        </a>
      </li>
    ))}
  </ul>
</nav>
